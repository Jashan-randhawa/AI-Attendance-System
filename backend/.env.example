# ── Microsoft Azure Face API ──────────────────────────────────────
AZURE_FACE_KEY=your_face_api_key_here
AZURE_FACE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# ── Azure Blob Storage ────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_BLOB_CONTAINER=attendance-photos

# ── Face Recognition Settings ─────────────────────────────────────
PERSON_GROUP_ID=attendance-group
MIN_CONFIDENCE=0.80

# ── MongoDB Atlas ─────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=attendance_db

# ── App Settings ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com

# ── Duplicate / quality thresholds ──────────────────────────────────────────
# DUPLICATE_THRESHOLD: cosine similarity at which a new enrollment is considered
# a duplicate of an existing person. Default 0.45.
# - Lower values (e.g. 0.40) = stricter, may produce false positives for twins/look-alikes
# - Higher values (e.g. 0.55) = more lenient, may allow same person to re-enroll
# Must be >= MIN_CONFIDENCE so we catch anyone the attendance system would recognize.
DUPLICATE_THRESHOLD=0.45

# MIN_CONFIDENCE: minimum similarity for live attendance recognition. Default 0.40.
MIN_CONFIDENCE=0.40
